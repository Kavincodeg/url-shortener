# Ignore node_modules and builds in subdirectories
**/node_modules/
**/dist/
**/build/

# Ignore sensitive env files (never commit real secrets)
# .env.example is allowed — it must contain ONLY placeholder values
**/.env
**/.env.local
**/.env.production
**/.env.staging
**/.env.development
**/.env.test
**/.env*.local

# Ignore local uploaded assets
**/public/uploads/*
!**/public/uploads/.gitkeep

# System logs and temp files
**/*.log
.DS_Store
.vscode/
.idea/
