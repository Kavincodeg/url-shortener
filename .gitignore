# Ignore node_modules and builds in subdirectories
**/node_modules/
**/dist/
**/build/

# Ignore sensitive env files (never commit real secrets)
**/.env
**/.env.local
**/.env.production
**/.env.staging
**/.env.development
**/.env*.local
**/.env.*
# Allow .env.example files (must contain only placeholders, NO real secrets)
!**/.env.example

# Ignore local uploaded assets
**/public/uploads/*
!**/public/uploads/.gitkeep

# System logs and temp files
**/*.log
.DS_Store
.vscode/
.idea/
