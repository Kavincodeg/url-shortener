PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&appName=url
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRE=7d
BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Google OAuth
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Email OTP (Gmail SMTP)
# Get App Password from: https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Resend / SendGrid (HTTP Email API options - bypasses SMTP blocks in production)
# Get Resend API Key from: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here
# EMAIL_FROM=Linko <onboarding@resend.dev>

# Get SendGrid API Key from: https://sendgrid.com/
# SENDGRID_API_KEY=your_sendgrid_api_key_here

